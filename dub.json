{
    "name": "d-onnxruntime",
    "description": "D bindings + a thin static-linkable C ABI shim over ONNX Runtime: load an .onnx model and score a batch of feature rows.",
    "license": "MIT",
    "authors": ["Alexander Shagarov"],

    "sourcePaths": ["source"],
    "importPaths": ["source"],

    "preBuildCommands-posix": [
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release",
        "cmake --build \"$PACKAGE_DIR/build\" -j --target onnxrt"
    ],
    "preBuildCommands-windows": [
        "cd /d \"$PACKAGE_DIR\" && cmake -S . -B build -DCMAKE_BUILD_TYPE=Release",
        "cd /d \"$PACKAGE_DIR\\build\" && cmake --build . --config Release -j --target onnxrt"
    ],

    "lflags-posix": [
        "-L$PACKAGE_DIR/build",
        "-L$PACKAGE_DIR/build/onnxruntime/sdk/lib"
    ],
    "lflags-windows": [
        "/LIBPATH:$PACKAGE_DIR/build",
        "/LIBPATH:$PACKAGE_DIR/build/onnxruntime/sdk/lib"
    ],
    "lflags-linux": [
        "-rpath=$$ORIGIN",
        "-rpath=$$ORIGIN/lib",
        "-rpath=$PACKAGE_DIR/build/onnxruntime/sdk/lib"
    ],
    "lflags-osx": [
        "-rpath", "@executable_path",
        "-rpath", "@executable_path/lib",
        "-rpath", "@executable_path/../Frameworks",
        "-rpath", "$PACKAGE_DIR/build/onnxruntime/sdk/lib"
    ],

    "libs-posix": ["onnxrt", "onnxruntime"],
    "libs-linux": ["stdc++"],
    "libs-osx": ["c++"],
    "libs-windows": ["onnxrt", "onnxruntime"],

    "configurations": [
        {
            "name": "library",
            "targetType": "staticLibrary"
        },
        {
            "name": "score_smoke",
            "targetType": "executable",
            "targetName": "score_smoke",
            "mainSourceFile": "examples/score_smoke.d"
        }
    ]
}
