{
    "name": "d-onnxruntime",
    "description": "D bindings + a thin static-linkable C ABI shim over ONNX Runtime: load an .onnx model and score a batch of feature rows.",
    "license": "MIT",
    "authors": ["Alexander Shagarov"],

    "sourcePaths": ["source"],
    "importPaths": ["source"],

    "preBuildCommands-posix": [
        "cd \"$PACKAGE_DIR\" && git submodule update --init --recursive extern/onnxruntime",
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release",
        "cmake --build \"$PACKAGE_DIR/build\" -j --target onnxrt"
    ],

    "lflags-posix": [
        "-L$PACKAGE_DIR/build",
        "-L$PACKAGE_DIR/build/onnxruntime/Release"
    ],
    "lflags-linux": [
        "-rpath=$$ORIGIN",
        "-rpath=$PACKAGE_DIR/build/onnxruntime/Release"
    ],
    "lflags-osx": [
        "-rpath", "@executable_path",
        "-rpath", "$PACKAGE_DIR/build/onnxruntime/Release"
    ],

    "libs-posix": ["onnxrt", "onnxruntime"],
    "libs-linux": ["stdc++"],
    "libs-osx": ["c++"],

    "configurations": [
        {
            "name": "library",
            "targetType": "staticLibrary"
        },
        {
            "name": "score_smoke",
            "targetType": "executable",
            "targetName": "score_smoke",
            "mainSourceFile": "examples/score_smoke.d"
        }
    ]
}
